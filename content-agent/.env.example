# ─────────────────────────────────────────────
# Simple Rabbit Content Agent — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# ── Twitter / X ──────────────────────────────
# Get these from: https://developer.twitter.com/en/portal/dashboard
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# ── Meta (Instagram, Facebook, Threads) ──────
# Get a long-lived Page Access Token from Meta Business Suite
# https://developers.facebook.com/tools/explorer/
META_ACCESS_TOKEN=

# Your Instagram Business Account User ID
INSTAGRAM_USER_ID=

# Your Facebook Page ID (not your personal profile)
FACEBOOK_PAGE_ID=
# Page-specific access token (may be same as META_ACCESS_TOKEN if it has page permissions)
FACEBOOK_PAGE_ACCESS_TOKEN=

# Your Threads User ID (same as Instagram User ID for most accounts)
THREADS_USER_ID=

# ── LinkedIn ─────────────────────────────────
# Get from: https://www.linkedin.com/developers/apps
# Scopes needed: w_member_social (personal) or w_organization_social (company page)
LINKEDIN_ACCESS_TOKEN=
# Format: "urn:li:person:XXXXXXXX" for personal or "urn:li:organization:XXXXXXXX" for company
LINKEDIN_PERSON_URN=

# ── Email (for approval notifications) ───────
# Gmail: use an App Password (not your regular password)
# Create one at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password

# Where to send the approval email
APPROVAL_EMAIL=leann@simplerabbit.studio
