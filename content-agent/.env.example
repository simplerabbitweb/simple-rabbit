# Simple Rabbit — Content Agent Environment Variables
# Copy this to .env and fill in your values.

# ── Anthropic ──────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Email (Gmail) ──────────────────────────────────────
# Use a Gmail App Password — NOT your real password.
# myaccount.google.com → Security → 2-Step Verification → App Passwords
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

# Where to send the daily drafts (usually same as GMAIL_ADDRESS)
NOTIFY_EMAIL=
