Options +FollowSymLinks
RewriteEngine On

# --- Force HTTPS ---
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# --- Redirect www → non-www ---
RewriteCond %{HTTP_HOST} ^www\.simplerabbit\.studio [NC]
RewriteRule ^ https://simplerabbit.studio%{REQUEST_URI} [L,R=301]

# Redirect .html URLs to clean URLs (301 permanent)
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# Serve clean URLs by appending .html internally
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.+)$ $1.html [L]

# --- HSTS: tell browsers to always use HTTPS ---
<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
</IfModule>

# Prevent HTML pages from being cached so updates show immediately
<FilesMatch "\.(html)$">
    Header always set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    Header always set Pragma "no-cache"
    Header always set Expires "Thu, 01 Jan 1970 00:00:00 GMT"
</FilesMatch>

# Allow images, SVG, JS to be cached for 1 week
<FilesMatch "\.(png|jpg|jpeg|svg|ico|css|js)$">
    Header set Cache-Control "public, max-age=604800"
</FilesMatch>
